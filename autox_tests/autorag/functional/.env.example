# Copy to .env and fill in your values. Used by functional tests (conftest.py).
# See tests/functional/README.md for full descriptions.

# RHOAI pipeline API
RHOAI_KFP_URL=
RHOAI_TOKEN=
RHOAI_PROJECT_NAME=
KFP_VERIFY_SSL=
AUTORAG_PIPELINE_PATH=

# Pipeline parameters (Kubernetes secret names and data locations; must exist in cluster)
TEST_DATA_SECRET_NAME=
TEST_DATA_BUCKET_NAME=
INPUT_DATA_SECRET_NAME=
INPUT_DATA_BUCKET_NAME=
LLAMA_STACK_SECRET_NAME=
LLAMA_STACK_VECTOR_IO_PROVIDER_ID=

# S3-compatible storage for artifact checks (optional; same as pipeline backend storage)
ARTIFACTS_AWS_ACCESS_KEY_ID=
ARTIFACTS_AWS_SECRET_ACCESS_KEY=
ARTIFACTS_AWS_S3_ENDPOINT=
ARTIFACTS_AWS_DEFAULT_REGION="us-east-1"
RHOAI_TEST_ARTIFACTS_BUCKET=

# Optional: timeout in seconds for pipeline run (default 3600)
# RHOAI_PIPELINE_RUN_TIMEOUT=3600

# Optional: skip TLS verify for self-signed cluster certs (true/false)
# KFP_VERIFY_SSL=false

# Kubernetes API for pod log fetching on failure (optional overrides)
# K8S_API_URL overrides the entire derived URL; K8S_API_PORT overrides just the port
# Default port: 443 for ROSA clusters, 6443 for standard OCP
# K8S_API_URL=https://api.my-cluster.example.com:443
# K8S_API_PORT=443


# Functional test: constrained model lists (JSON arrays, e.g. '["model-a", "model-b"]')
# FUNC_TEST_EMBEDDINGS_MODELS=
# FUNC_TEST_GENERATION_MODELS=

# Functional test: filter test configs by tags (comma-separated, e.g. smoke,milvus-lite)
# FUNCTIONAL_TESTS_TAGS=

# =============================================================================
# Env variables to test notebooks (can be extracted from kubernetes secrets as well)
# Note: these variables need to have the same names as one would expect in production
# =============================================================================

# Llama Stack env variables
LLAMA_STACK_CLIENT_BASE_URL=
LLAMA_STACK_CLIENT_API_KEY=


# AWS env variables for the indexing notebooks execution
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=