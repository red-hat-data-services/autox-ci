# =============================================================================
# AutoML: Cluster & Pipeline API
# =============================================================================
RHOAI_URL=
RHOAI_KFP_URL=
RHOAI_TOKEN=
RHOAI_PROJECT_NAME=
KFP_VERIFY_SSL=true

# =============================================================================
# AutoML: S3 Storage
# =============================================================================
AWS_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=

# Location where pipeline artifacts are saved, configured in the DSPA settings
RHOAI_TEST_ARTIFACTS_BUCKET=

# Below variables are passed to the automl pipelines as train_data_bucket_name, train_data_secret_name, respectively
RHOAI_TRAIN_DATA_BUCKET=
RHOAI_TRAIN_S3_SECRET_NAME=s3-connection

# =============================================================================
# AutoML: Pipeline YAML (local file path or URL)
# =============================================================================
AUTOML_TABULAR_PIPELINE_PATH=
AUTOML_TIMESERIES_PIPELINE_PATH=
AUTOML_FUNCTIONAL_TESTS_TAGS=
AUTOML_FUNCTIONAL_TEST_KEEP_ARTIFACTS=false
KFP_DISABLE_EXECUTION_CACHING_BY_DEFAULT=true

# =============================================================================
# AutoML: Model Serving (optional)
# =============================================================================
RHOAI_DEPLOY_AFTER_TRAINING=false
RHOAI_SERVING_IMAGE=
RHOAI_SERVING_RUNTIME_NAME=kserve-autogluonserver
RHOAI_CREATE_SERVING_RUNTIME=false
RHOAI_INFERENCE_TIMEOUT=600
# Existing Data Connection secret to use as KServe storage key (leave blank to create a temporary one)
RHOAI_KSERVE_STORAGE_KEY=
# HardwareProfile for the predictor pod (oc get hardwareprofile -n redhat-ods-applications)
RHOAI_HARDWARE_PROFILE_NAME=default-profile
RHOAI_HARDWARE_PROFILE_NAMESPACE=redhat-ods-applications
RHOAI_HARDWARE_PROFILE_RESOURCE_VERSION=
RHOAI_KSERVE_CA_BUNDLE_CONFIGMAP=
RHOAI_PREDICTOR_CPU=2
RHOAI_PREDICTOR_MEMORY=4Gi

# =============================================================================
# AutoML: Notebook runner (optional)
# =============================================================================
RHOAI_NOTEBOOK_RUNNER_IMAGE=

# =============================================================================
# Test filtering & timeouts
# =============================================================================
RHOAI_TEST_CONFIG_TAGS=
RHOAI_PIPELINE_RUN_TIMEOUT=3600
RHOAI_KFP_POLL_INTERVAL_SECONDS=25
