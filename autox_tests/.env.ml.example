# =============================================================================
# AutoML: Cluster & Pipeline API
# =============================================================================
RHOAI_URL=
RHOAI_KFP_URL=
RHOAI_TOKEN=
RHOAI_PROJECT_NAME=
KFP_VERIFY_SSL=true
S3_SSL_VERIFY=true
# RHOAI_CREATE_DSPA=false

# =============================================================================
# AutoML: S3 Storage
# =============================================================================
AWS_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=
RHOAI_TEST_DATA_BUCKET=
RHOAI_TEST_ARTIFACTS_BUCKET=
RHOAI_TEST_S3_SECRET_NAME=s3-connection
# RHOAI_TRAIN_S3_SECRET_NAME=  # preferred over RHOAI_TEST_S3_SECRET_NAME when set

# =============================================================================
# AutoML: Pipeline YAML (local file path or URL)
# =============================================================================
AUTOML_TABULAR_PIPELINE_PATH=
AUTOML_TIMESERIES_PIPELINE_PATH=
AUTOML_TRAIN_DATA_BUCKET_NAME=
AUTOML_FUNCTIONAL_TESTS_TAGS=
AUTOML_FUNCTIONAL_TEST_KEEP_ARTIFACTS=false
# Set to true to upload datasets from autox_tests/automl/data/ to S3 before tests run.
# When unset (default), datasets are assumed to already be present in S3.
AUTOML_UPLOAD_TEST_DATASETS=false
KFP_DISABLE_EXECUTION_CACHING_BY_DEFAULT=true

# =============================================================================
# AutoML: Model Serving (optional)
# =============================================================================
RHOAI_DEPLOY_AFTER_TRAINING=false
RHOAI_SERVING_IMAGE=
RHOAI_SERVING_RUNTIME_NAME=kserve-autogluonserver
RHOAI_CREATE_SERVING_RUNTIME=false
RHOAI_INFERENCE_TIMEOUT=600
RHOAI_KSERVE_CA_BUNDLE_CONFIGMAP=
RHOAI_PREDICTOR_CPU=2
RHOAI_PREDICTOR_MEMORY=4Gi

# =============================================================================
# AutoML: Notebook runner (optional)
# =============================================================================
RHOAI_NOTEBOOK_RUNNER_IMAGE=

# =============================================================================
# Test filtering & timeouts
# =============================================================================
RHOAI_TEST_CONFIG_TAGS=
RHOAI_PIPELINE_RUN_TIMEOUT=3600
RHOAI_KFP_POLL_INTERVAL_SECONDS=25
