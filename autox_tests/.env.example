# AutoML and AutoRAG use different clusters, so they need separate .env files:
#   .env.ml  — AutoML tests (tabular + timeseries)
#   .env.rag — AutoRAG tests (documents RAG optimization)
#
# Usage:
#   ./run_tests.sh --env-file autox_tests/.env.ml  "functional and tabular"
#   ./run_tests.sh --env-file autox_tests/.env.rag "functional"

# =============================================================================
# Shared variables (same names used by both, values differ per cluster)
# =============================================================================
RHOAI_URL=
RHOAI_KFP_URL=
RHOAI_TOKEN=
RHOAI_PROJECT_NAME=
KFP_VERIFY_SSL=true
AWS_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
RHOAI_TEST_DATA_BUCKET=
RHOAI_TEST_ARTIFACTS_BUCKET=
RHOAI_TEST_S3_SECRET_NAME=s3-connection

# =============================================================================
# AutoML only
# =============================================================================
RHOAI_PIPELINE_YAML_TABULAR=
RHOAI_PIPELINE_YAML_TIMESERIES=
AUTOML_TABULAR_PIPELINE_PATH=
AUTOML_TIMESERIES_PIPELINE_PATH=
AUTOML_TRAIN_DATA_SECRET_NAME=s3-connection
AUTOML_TRAIN_DATA_BUCKET_NAME=
AUTOML_FUNCTIONAL_TESTS_TAGS=
AUTOML_FUNCTIONAL_TEST_KEEP_ARTIFACTS=false
RHOAI_DEPLOY_AFTER_TRAINING=false
RHOAI_SERVING_IMAGE=
RHOAI_SERVING_RUNTIME_NAME=kserve-autogluonserver
RHOAI_CREATE_SERVING_RUNTIME=false
RHOAI_INFERENCE_TIMEOUT=600
RHOAI_KSERVE_CA_BUNDLE_CONFIGMAP=
RHOAI_NOTEBOOK_RUNNER_IMAGE=

# =============================================================================
# AutoRAG only
# =============================================================================
AUTORAG_PIPELINE_PATH=
TEST_DATA_SECRET_NAME=
TEST_DATA_BUCKET_NAME=
TEST_DATA_KEY=
INPUT_DATA_SECRET_NAME=
INPUT_DATA_BUCKET_NAME=
INPUT_DATA_KEY=
LLAMA_STACK_SECRET_NAME=
LLAMA_STACK_VECTOR_IO_PROVIDER_ID=
ARTIFACTS_AWS_ACCESS_KEY_ID=
ARTIFACTS_AWS_SECRET_ACCESS_KEY=
ARTIFACTS_AWS_S3_ENDPOINT=
ARTIFACTS_AWS_DEFAULT_REGION=us-east-1
LLAMA_STACK_CLIENT_BASE_URL=
LLAMA_STACK_CLIENT_API_KEY=
LLAMA_STACK_VECTOR_IO_PROVIDER_ID_MILVUS_LITE=
LLAMA_STACK_VECTOR_IO_PROVIDER_ID_MILVUS_REMOTE=
FUNC_TEST_EMBEDDINGS_MODELS=
FUNC_TEST_GENERATION_MODELS=
K8S_API_URL=

# =============================================================================
# Optional: Test filtering & timeouts
# =============================================================================
RHOAI_TEST_CONFIG_TAGS=
FUNCTIONAL_TESTS_TAGS=
RHOAI_PIPELINE_RUN_TIMEOUT=3600
RHOAI_KFP_POLL_INTERVAL_SECONDS=25
