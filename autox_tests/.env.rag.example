# =============================================================================
# AutoRAG: Cluster & Pipeline API
# =============================================================================
RHOAI_URL=
RHOAI_KFP_URL=
RHOAI_TOKEN=
RHOAI_PROJECT_NAME=
KFP_VERIFY_SSL=true
# RHOAI_CREATE_DSPA=false

RHOAI_TEST_S3_SECRET_NAME=s3-connection
# RHOAI_SKIP_S3_SECRET_SETUP=true
# RHOAI_S3_SECRET_OVERWRITE_KEYS=true

# =============================================================================
# AutoRAG: Managed pipelines & DSPA (default when RHOAI_KFP_URL is unset)
# =============================================================================
RHOAI_MANAGED_PIPELINE_AUTORAG=documents-rag-optimization-pipeline
RHOAI_MANAGED_PIPELINE_WAIT_TIMEOUT=300
RHOAI_DSPA_NAME=dspa
RHOAI_DSPA_DSP_VERSION=v2
# RHOAI_DSPA_MANAGED_PIPELINES_IMAGE=quay.io/rhoai/odh-pipelines-components-rhel9@sha256:...
# RHOAI_DSPA_READY_WAIT_TIMEOUT=600
# RHOAI_DSPA_ROUTE_WAIT_TIMEOUT=300
# RHOAI_USE_MANAGED_PIPELINES=false

# =============================================================================
# AutoRAG: Pipeline & parameters
# =============================================================================
AUTORAG_PIPELINE_PATH=
TEST_DATA_SECRET_NAME=
TEST_DATA_BUCKET_NAME=
INPUT_DATA_BUCKET_NAME=
INPUT_DATA_SECRET_NAME=
OGX_SECRET_NAME=

# =============================================================================
# AutoRAG: S3 for artifact validation
# =============================================================================
ARTIFACTS_AWS_ACCESS_KEY_ID=
ARTIFACTS_AWS_SECRET_ACCESS_KEY=
ARTIFACTS_AWS_S3_ENDPOINT=
ARTIFACTS_AWS_DEFAULT_REGION=us-east-1
RHOAI_TEST_ARTIFACTS_BUCKET=

# =============================================================================
# AutoRAG: OGX credentials (for notebook execution)
# =============================================================================
OGX_CLIENT_BASE_URL=
OGX_CLIENT_API_KEY=

# =============================================================================
# AutoRAG: AWS S3 location and credentials (for notebook execution)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=
AWS_DEFAULT_REGION=
AWS_S3_BUCKET=

# =============================================================================
# AutoRAG: Constrained model lists
# =============================================================================
FUNC_TEST_EMBEDDING_MODELS=
FUNC_TEST_GENERATION_MODELS=

# =============================================================================
# AutoRAG: Kubernetes API for pod log fetching
# =============================================================================
K8S_API_URL=

# =============================================================================
# Test filtering & timeouts
# =============================================================================
FUNCTIONAL_TESTS_TAGS=
RHOAI_PIPELINE_RUN_TIMEOUT=3600
RHOAI_KFP_POLL_INTERVAL_SECONDS=25
