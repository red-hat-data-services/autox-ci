# =============================================================================
# AutoRAG: Cluster & Pipeline API
# =============================================================================
RHOAI_KFP_URL=
RHOAI_TOKEN=
RHOAI_PROJECT_NAME=
KFP_VERIFY_SSL=true
S3_SSL_VERIFY=true
# RHOAI_CREATE_DSPA=false

# =============================================================================
# AutoRAG: Pipeline & parameters
# =============================================================================
AUTORAG_PIPELINE_PATH=
TEST_DATA_SECRET_NAME=
TEST_DATA_BUCKET_NAME=
INPUT_DATA_BUCKET_NAME=
INPUT_DATA_SECRET_NAME=
LLAMA_STACK_SECRET_NAME=

# =============================================================================
# AutoRAG: S3 for artifact validation
# =============================================================================
ARTIFACTS_AWS_ACCESS_KEY_ID=
ARTIFACTS_AWS_SECRET_ACCESS_KEY=
ARTIFACTS_AWS_S3_ENDPOINT=
ARTIFACTS_AWS_DEFAULT_REGION=us-east-1
RHOAI_TEST_ARTIFACTS_BUCKET=

# S3 data locations
AUTORAG_S3_SECRET_NAME=
AUTORAG_DSPA_NAMESPACE=
AUTORAG_DSPA_NAME=

# =============================================================================
# AutoRAG: Llama Stack credentials (for notebook execution)
# =============================================================================
LLAMA_STACK_CLIENT_BASE_URL=
LLAMA_STACK_CLIENT_API_KEY=

# =============================================================================
# AutoRAG: AWS S3 location and credentials (for notebook execution)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=
AWS_DEFAULT_REGION=
AWS_S3_BUCKET=

# =============================================================================
# AutoRAG: Constrained model lists
# =============================================================================
FUNC_TEST_EMBEDDINGS_MODELS=
FUNC_TEST_GENERATION_MODELS=

# =============================================================================
# AutoRAG: Kubernetes API for pod log fetching
# =============================================================================
K8S_API_URL=

# =============================================================================
# AutoRAG: Dataset upload (optional)
# =============================================================================
# Set to true to upload datasets from autox_tests/autorag/data/ to S3 before tests run.
# When unset (default), datasets are assumed to already be present in S3.
AUTORAG_UPLOAD_TEST_DATASETS=false

# =============================================================================
# Test filtering & timeouts
# =============================================================================
FUNCTIONAL_TESTS_TAGS=
RHOAI_PIPELINE_RUN_TIMEOUT=3600
RHOAI_KFP_POLL_INTERVAL_SECONDS=25
