# Copy to tests/.env and fill in values. Variables already set in the process environment
# are not overwritten by this file (export or CI secrets take precedence).
#
# Install: pip install -e ".[test_rhoai]"
# (pulls kfp, boto3, kubernetes, and pytest extras)

# =============================================================================
# Kubeflow / OpenShift AI API (all pipelines that submit runs)
# =============================================================================
# OpenShift API URL (same token as RHOAI_TOKEN). Used to create RHOAI_PROJECT_NAME if missing and
# to create/update the S3 secret above — same flow for AutoGluon and AutoRAG optimization tests.
RHOAI_URL=
# KFP HTTP API base URL (Data Science Pipelines route), trailing slash optional.
RHOAI_KFP_URL=
# Aliases used by some clients (same values as RHOAI_* above):
# KFP_HOST=
RHOAI_TOKEN=
# KFP_TOKEN=
# Namespace where the pipeline runs (secrets below must exist here).
RHOAI_PROJECT_NAME=kfp-integration-test
# KFP_NAMESPACE=

# =============================================================================
# S3 + shared Kubernetes secret (AutoML train data + AutoRAG benchmark + input corpus)
# =============================================================================
AWS_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Bucket for uploaded test fixtures (AutoML CSVs; AutoRAG document tree + benchmark JSON).
RHOAI_TEST_DATA_BUCKET=
# Create the data bucket on the S3 endpoint if it does not exist (requires CreateBucket). Set false to disable.
# RHOAI_TEST_S3_CREATE_BUCKET_IF_MISSING=true

# Name of the secret in RHOAI_PROJECT_NAME whose data includes AWS_ACCESS_KEY_ID,
# AWS_SECRET_ACCESS_KEY, AWS_S3_ENDPOINT, AWS_DEFAULT_REGION. Used for AutoML components and
# for both AutoRAG pipeline S3 secret parameters (benchmark JSON and document corpus may use different buckets).
RHOAI_TEST_S3_SECRET_NAME=s3-connection



# S3 (boto3), KFP API (kfp.Client): default verify TLS. Set false for self-signed MinIO/S3 or pipeline routes.
# RHOAI_HTTPS_VERIFY=true
# Legacy alias (same effect): KFP_VERIFY_SSL=true

# TLS for the OpenShift API client (kubernetes calls to RHOAI_URL):
# - Default: skip TLS verification (typical when the API uses a self-signed cert and you do not install the CA).
# - Enterprise / proper PKI: set RHOAI_OPENSHIFT_CA_BUNDLE_PATH to a PEM file with the API server CA,
#   OR set RHOAI_OPENSHIFT_CA_DATA to the kubeconfig-style base64(single PEM or bundle).
# - To require verification: either supply a CA as above, or set RHOAI_OPENSHIFT_API_INSECURE_TLS=false
#   together with one of the CA variables (otherwise configuration is invalid).
# RHOAI_OPENSHIFT_API_INSECURE_TLS=true
# RHOAI_OPENSHIFT_CA_BUNDLE_PATH=
# RHOAI_OPENSHIFT_CA_DATA=

# Optional: artifact bucket for checks; defaults to RHOAI_TEST_DATA_BUCKET when unset.
# RHOAI_TEST_ARTIFACTS_BUCKET=

# =============================================================================
# Optional: DataSciencePipelinesApplication (DSPA) in the test namespace
# =============================================================================
# Create a DSPA CR via the Kubernetes API so the operator deploys a pipeline server. When enabled,
# RHOAI_KFP_URL may be omitted — the suite discovers the pipeline API from the OpenShift Route (ds-pipeline*).
# Requires Data Science Pipelines Operator / compatible CRD on the cluster.
# RHOAI_CREATE_DSPA=false
# RHOAI_DSPA_API_GROUP=datasciencepipelinesapplications.opendatahub.io
# RHOAI_DSPA_API_VERSION=v1
# RHOAI_DSPA_PLURAL=datasciencepipelinesapplications
# RHOAI_DSPA_ROUTE_NAME_PREFIX=ds-pipeline
# RHOAI_DSPA_ROUTE_WAIT_TIMEOUT=300
# RHOAI_DSPA_READY_WAIT_TIMEOUT=600
# RHOAI_DSPA_READY_BUFFER_SECONDS=30
# In-cluster S3 API URL for the DSPA CR only (scheme/host/port). Use when AWS_S3_ENDPOINT uses HTTPS with
# a cert the cluster cannot trust — e.g. http://minio.minio.svc:9000. Test-runner uploads still use AWS_S3_ENDPOINT.
# INCLUSTER_AWS_S3_ENDPOINT=

# =============================================================================
# Optional: JSON data_mode=existing_s3 (AutoML + AutoRAG)
# =============================================================================
# When a tests/config/*.json entry omits *bucket* fields, these supply the default bucket and
# an optional key prefix (applied to relative keys in JSON when the bucket is not set per entry).
# TEST_DATA_SOURCE_BUCKET=
# TEST_DATA_SOURCE_PREFIX=

# =============================================================================
# AutoRAG optimization — Llama Stack only
# =============================================================================
# Secret must include LLAMA_STACK_CLIENT_API_KEY, LLAMA_STACK_CLIENT_BASE_URL.
LLAMA_STACK_SECRET_NAME=
# Vector I/O provider id registered in Llama Stack (e.g. Milvus).
LLAMA_STACK_VECTOR_IO_PROVIDER_ID=

# Optional fallbacks for JSON data_mode=existing_s3 when the config omits test_data_bucket / input_data_bucket
# (object keys still come from tests/config/autorag_test_configs.json).
# TEST_DATA_BUCKET_NAME=
# TEST_DATA_KEY=
# INPUT_DATA_BUCKET_NAME=
# INPUT_DATA_KEY=

# =============================================================================
# Optional: pytest behaviour (root tests/ suite)
# =============================================================================
# Run only JSON scenarios whose tags intersect this comma-separated list (e.g. smoke).
# Also gates negative pipeline tests: include tabular, timeseries, and/or autorag to run those
# suites (same strings as JSON scenario tags). Example: smoke,tabular
# RHOAI_TEST_CONFIG_TAGS=smoke

# Precompiled pipeline IR (pipeline.yaml): local path or download from pipelines-components.
# If unset, each suite downloads from raw.githubusercontent.com (default repo/ref below).
# RHOAI_PIPELINE_YAML_TABULAR=
# RHOAI_PIPELINE_YAML_TIMESERIES=
# RHOAI_PIPELINE_YAML_AUTORAG=
# RHOAI_PIPELINES_COMPONENTS_REPO=red-hat-data-services/pipelines-components
# RHOAI_PIPELINES_COMPONENTS_REF=rhoai-3.4

# RHOAI_PIPELINE_RUN_TIMEOUT=3600
# Optional override for negative pipeline tests (defaults to RHOAI_PIPELINE_RUN_TIMEOUT).
# RHOAI_PIPELINE_NEGATIVE_RUN_TIMEOUT=
# How often to poll KFP for run/task status (and print progress to the terminal).
# RHOAI_KFP_POLL_INTERVAL_SECONDS=25
# Optional: @dsl.pipeline name=... for filtering the compiled root DAG task from progress lines.
# RHOAI_KFP_PIPELINE_DISPLAY_NAME=autogluon-tabular-training-pipeline
