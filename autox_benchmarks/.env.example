# AutoX Benchmarks — copy to .env in this directory and fill in.
# Loaded automatically by orchestrators, compare UI, and integration tests.
# Shell / CI variables already set take precedence over values in .env.
#
# Names align with autox_tests (.env.ml / .env.rag) where possible.

# =============================================================================
# Kubeflow Pipelines (required)
# =============================================================================
BENCHMARK_KFP_HOST=
# Aliases: RHOAI_KFP_URL, KFP_HOST
BENCHMARK_KFP_NAMESPACE=
# Aliases: RHOAI_PROJECT_NAME, KFP_NAMESPACE
BENCHMARK_KFP_TOKEN=
# Aliases: RHOAI_TOKEN, KFP_API_TOKEN, KFP_TOKEN
# BENCHMARK_KFP_TOKEN_FILE=/path/to/kfp_api_token.txt
BENCHMARK_KFP_EXPERIMENT_NAME=autogluon-benchmark

# =============================================================================
# Storage buckets
# =============================================================================
# AutoML (required for automl_benchmark)
BENCHMARK_TRAIN_DATA_BUCKET_NAME=
# Aliases: AUTOML_TRAIN_DATA_BUCKET_NAME, RHOAI_TEST_DATA_BUCKET

# AutoRAG (required for autorag_benchmark)
# BENCHMARK_INPUT_DATA_BUCKET_NAME=
# BENCHMARK_TEST_DATA_BUCKET_NAME=

# Optional S3 layout / uploads
# BENCHMARK_ARTIFACT_S3_PREFIX=autogluon-tabular-training-pipeline
# BENCHMARK_TIMESERIES_ARTIFACT_S3_PREFIX=autogluon-timeseries-training-pipeline
# BENCHMARK_S3_PREFIX=benchmarks
# BENCHMARK_UPLOAD_RESULTS=true

# =============================================================================
# Pipeline secrets (cluster secret names referenced by KFP)
# =============================================================================
# AutoML
BENCHMARK_TRAIN_DATA_SECRET_NAME=
# Alias: RHOAI_TEST_S3_SECRET_NAME

# AutoRAG
# BENCHMARK_INPUT_DATA_SECRET_NAME=
# BENCHMARK_TEST_DATA_SECRET_NAME=
# BENCHMARK_OGX_SECRET_NAME=
# BENCHMARK_VECTOR_IO_PROVIDER_ID=

# Optional: static compiled pipeline YAML (skips Git compile)
# BENCHMARK_TABULAR_PACKAGE_PATH=
# BENCHMARK_TIMESERIES_PACKAGE_PATH=
# BENCHMARK_PACKAGE_PATH=   # AutoRAG; alias RAG_PACKAGE_PATH, AUTORAG_PIPELINE_PATH

# =============================================================================
# S3 client (leaderboard discovery, result uploads, dataset generation)
# =============================================================================
AWS_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# =============================================================================
# Optional run overrides (merged over benchmark.yaml)
# =============================================================================
# BENCHMARK_TOP_N=2
# BENCHMARK_OPTIMIZATION_METRIC=faithfulness
# BENCHMARK_OPTIMIZATION_MAX_RAG_PATTERNS=8
# BENCHMARK_POLL_INTERVAL_SECONDS=15
# BENCHMARK_TIMEOUT_SECONDS=7200
# BENCHMARK_ENABLE_CACHING=false
# BENCHMARK_RUN_NAME_PREFIX=my-benchmark

# =============================================================================
# Tooling (optional)
# =============================================================================
# BENCHMARK_ENV_FILE=/path/to/custom.env
# BENCHMARK_CONFIG_PATH=config/benchmark.yaml
# BENCHMARK_RUN_INTEGRATION=1
